# .env.example - VAIC - AI Care Pathway Coordinator
#
# Placeholders only. NEVER commit a real value to this file.
# Copy to .env for local development. .env is gitignored and is never read by CI.

# ---- Application ----------------------------------------------------------
# Consumed by: the FastAPI/agent entrypoint. Source: local = this file; deployed = platform variables.
APP_ENV=local
LOG_LEVEL=debug
API_PORT=8000

# ---- State and events (Redis) ---------------------------------------------
# Consumed by: src/vaic/state (Redis client) and the event bus. Local = a local container.
# The seed script refuses non-local targets.
REDIS_URL=redis://localhost:6379/0

# Discrete connection vars for the shared remote Redis/Valkey cache. Not consumed by
# application code today (RedisRepository takes REDIS_URL) - documented here for whoever
# provisions the deployment target.
REDIS_PUBLISH_PORT=REPLACE_ME
REDIS_PASSWORD_1=REPLACE_ME
REDIS_PASSWORD_2=REPLACE_ME
REDIS_HOST=REPLACE_ME
REDIS_USER_NAME=REPLACE_ME

# ---- PostgreSQL -------------------------------------------------------------
# Consumed by: src/vaic/config.py (Settings.postgres_url) and src/vaic/state/postgres.py
# (the async SQLAlchemy engine singleton). Optional durable-store path (OI-15) - requires
# `uv sync --extra sql`; the app's default store remains Redis/in-memory.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_NAME=nxcare
POSTGRES_USER=nxcare
POSTGRES_PASSWORD=REPLACE_ME

# ---- Model providers ------------------------------------------------------
# Consumed by: the provider client layer (src/vaic/agents, src/vaic/forecast).
# Keys are spend authorities - scope to the minimum and rotate on exposure.
# Hosted API for the Coordinator/Disruption reasoning seats:
LLM_API_KEY=REPLACE_ME
LLM_API_BASE_URL=https://api.example-provider.invalid/v1
# Self-hosted Qwen endpoint for Intake / Journey / forecast-LLM:
QWEN_BASE_URL=http://localhost:8001/v1
QWEN_API_KEY=REPLACE_ME_IF_REQUIRED

# ---- Public / client-exposed (frontend) -----------------------------------
# WARNING: anything the browser can read is PUBLIC. Never put a secret here.
VITE_API_BASE_URL=http://localhost:8000

# ---- Simulator ------------------------------------------------------------
# Consumed by: src/vaic/simulator. Fixed seed keeps demo metrics reproducible (BR-15, NFR-REL-05).
SIM_SEED=42
SIM_PATIENT_COUNT=80

# ---- Notes ----------------------------------------------------------------
# Payment is a flag only - the app processes no money (AS-02): NO payment-provider key.
# SMS is simulated in the demo (BR-25): NO SMS-provider key.
# Add these only if the integration becomes real (docs/specs/09-integration-interface.md).
